# ============================================================================
# DATA — too large for GitHub (~100 GB); distributed separately.
# Keep the build .do files in Data/<source>/, exclude all actual data.
# ============================================================================

# Raw vendor data folders (huge) — exclude wholesale
Data/eMAXX/Raw eMAXX/
Data/**/Raw Data/

# Built data + working files
Data/Working Files/
Data/**/*.dta
Data/**/*.csv
Data/**/*.txt
Data/**/*.xls
Data/**/*.xlsx
Data/**/*.pdf

# ---- Generated analysis output --------------------------------------------
Paper Replication/Figures and Tables/

# ---- Internal working notes (delete before submission) --------------------
_INTERNAL_DELETE_BEFORE_SUBMISSION/

# ---- OS / editor / logs ---------------------------------------------------
.DS_Store
*.stswp
~*
*.log
